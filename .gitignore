# ── Rust / Cargo ──────────────────────────────────────────────
# Build output (workspace + tauri crate). Cargo.lock IS committed (this is an app).
target/
**/target/
backend/target/
frontend/src-tauri/target/

# ── Node / frontend ───────────────────────────────────────────
node_modules/
frontend/node_modules/
.npm/
.pnpm-store/

# ── SvelteKit / Vite build output ─────────────────────────────
frontend/build/
frontend/.svelte-kit/
frontend/.vite/
frontend/dist/
*.tsbuildinfo
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Tauri generated ───────────────────────────────────────────
# Schemas/permissions are regenerated by the tauri build.
frontend/src-tauri/gen/

# ── Runtime / local state (must never be committed) ───────────
# Per-device cryptographic identity and trust store.
identity.key
**/identity.key
share_settings.json
**/share_settings.json
trusted_devices.json
**/trusted_devices.json
# Received files default landing folder (next to the exe).
files/
frontend/src-tauri/files/

# ── Logs / crash dumps ────────────────────────────────────────
*.log
hs_err_pid*.log

# ── Editor / OS cruft ─────────────────────────────────────────
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
