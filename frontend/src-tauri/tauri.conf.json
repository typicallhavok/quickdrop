{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quickdrop",
  "version": "0.1.0",
  "identifier": "io.havok.quickdrop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Quickdrop",
        "width": 960,
        "height": 640,
        "resizable": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Havok",
    "copyright": "© 2026 Havok",
    "category": "Utility",
    "shortDescription": "Encrypted peer-to-peer file & clipboard transfer",
    "longDescription": "Quickdrop is a fast, secure, peer-to-peer file and clipboard transfer app for your local network — no cloud, no accounts. Transfers are end-to-end encrypted and can resume after interruption.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  }
}
